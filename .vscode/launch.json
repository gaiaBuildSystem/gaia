{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Deno",
            "program": "${file}",
            "cwd": "${workspaceFolder}/../",
            "runtimeExecutable": "/opt/deno/bin/deno",
            "runtimeArgs": [
                "run",
                "--allow-all",
                "--inspect-wait"
            ],
            "attachSimplePort": 9229,
            "args": [
                "--buildPath",
                "${config:build_path}",
                "--distro",
                "${config:distro_path}"
            ],
            "internalConsoleOptions": "openOnSessionStart"
        }
    ],
    "inputs": [
        {
            "id": "args",
            "description": "Arguments to pass to the program",
            "type": "promptString"
        }
    ],
    "compounds": []
}
