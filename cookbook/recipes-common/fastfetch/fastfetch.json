{
    "name": "fastfetch",
    "type": "application",
    "priority": 0,
    "support": [
        "linux/amd64",
        "linux/arm64"
    ],
    "source": "https://github.com/gaiaBuildSystem/fastfetch.git",
    "version": "2.38.0",
    "ref": {
        "linux/amd64": "8e17665e813767c85980a21db70c9c8f79c74d24",
        "linux/arm64": "8e17665e813767c85980a21db70c9c8f79c74d24"
    },
    "env": {
        "ALIAS_NEOFETCH": "true"
    },
    "hostAsContainer": true,
    "containerImage": {
        "image": "debian",
        "tag": "bookworm"
    },
    "hostDeps": [
        "binutils",
        "build-essential",
        "cmake",
        "libdrm-dev",
        "libglib2.0-dev",
        "libdconf-dev",
        "libchafa-dev",
        "zlib1g-dev",
        "libdbus-1-dev",
        "libosmesa6-dev",
        "libopencl-clang-15-dev",
        "directx-headers-dev"
    ],
    "targetDeps": [
        "libdrm2",
        "libosmesa6"
    ],
    "fetchRecipes": [
        "fetch.ts"
    ],
    "buildRecipes": [
        "build.sh"
    ],
    "deployRecipes": [
        "deploy.ts"
    ],
    "sbomRecipes": [
        "fastfetch-sbom.ts"
    ]
}
